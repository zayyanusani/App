function register() {
  let u = document.getElementById('username').value;
  let p = document.getElementById('password').value;
  if (!u || !p) return authMsg("Please fill in both fields.");
  if (localStorage.getItem(u)) return authMsg("Username already registered!");
  localStorage.setItem(u, p);
  authMsg("Registration successful! Now you can log in.");
}
function login() {
  let u = document.getElementById('username').value;
  let p = document.getElementById('password').value;
  if (!u || !p) return authMsg("Please fill in both fields.");
  if (localStorage.getItem(u) === p) {
    // Hide auth, show dashboard
    document.getElementById('auth-section').style.display = 'none';
    document.getElementById('dashboard').style.display = '';
    document.getElementById('display-username').innerText = u;
  } else {
    authMsg("Incorrect username or password.");
  }
}
function startCourse(youtubeURL) {
  window.location.href = youtubeURL; // Redirect to YouTube
}
function authMsg(msg) {
  document.getElementById('auth-message').innerText = msg;
}