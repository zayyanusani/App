body {
  font-family: sans-serif;
  background: #f9f9f9;
  margin: 40px;
}
#auth-section, #dashboard {
  background: white;
  padding: 2em;
  border-radius: 8px;
  max-width: 400px;
  margin: auto;
  box-shadow: 0 2px 8px #ccc;
}
input {
  margin: 0.5em 0;
  padding: 0.5em;
  width: 100%;
}
button {
  margin: 0.5em 0.25em;
  padding: 0.5em 1em;
  cursor: pointer;
}