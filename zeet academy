<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Academy Website</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>
  <div id="auth-section">
    <h2>Create Account / Login</h2>
    <input type="text" id="username" placeholder="Username"><br>
    <input type="password" id="password" placeholder="Password"><br>
    <button onclick="register()">Register</button>
    <button onclick="login()">Login</button>
    <div id="auth-message"></div>
  </div>
  <div id="dashboard" style="display: none;">
    <h2>Welcome, <span id="display-username"></span>!</h2>
    <h3>Select a Course:</h3>
    <ul>
      <li>
        Communication Skills Basics
        <button onclick="startCourse('https://www.youtube.com/yourChannel1')">Start</button>
      </li>
      <li>
        Public Speaking
        <button onclick="startCourse('https://www.youtube.com/yourChannel2')">Start</button>
      </li>
      <!-- Add more courses here -->
    </ul>
  </div>
  <script src="app.js"></script>
</body>
</html>